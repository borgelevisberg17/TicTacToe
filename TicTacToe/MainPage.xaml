<?xml version="1.0" encoding="utf-8"?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    
    xmlns:local="clr-namespace:TicTacToe"
    
    xmlns:audio="clr-namespace:Plugin.Maui.Audio;assembly=Plugin.Maui.Audio"
    
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TicTacToe.MainPage"
    BackgroundColor="#121212">
    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior
            StatusBarColor="#121212"
            StatusBarStyle="LightContent" />
    </ContentPage.Behaviors>
    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="AccentColor">#03DAC6</Color>
            <Color x:Key="PrimaryColor">#BB86FC</Color>
            <Color x:Key="SurfaceColor">#1E1E1E</Color>
            <Color x:Key="OnSurfaceColor">#FFFFFF</Color>

            <Style x:Key="GameButtonStyle" TargetType="Button">
                <Setter Property="FontSize" Value="48" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="BackgroundColor" Value="#2C2C2C" />
                <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BorderWidth" Value="0" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Scale" Value="0.92" />
                                    <Setter Property="BackgroundColor" Value="#3D3D3D" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style x:Key="ControlButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#2C2C2C" />
                <Setter Property="TextColor" Value="#FFFFFF" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="HeightRequest" Value="60" />
                <Setter Property="ContentLayout" Value="Top,4" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Scale" Value="0.95" />
                                    <Setter Property="BackgroundColor" Value="#3D3D3D" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style x:Key="DropdownItemStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#333333" />
                <Setter Property="TextColor" Value="#FFFFFF" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="15,10" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="25" RowSpacing="15">
        <!-- Modern Header -->
        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
            <Label Text="TIC TAC TOE"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryColor}"
                   HorizontalOptions="Center"
                   CharacterSpacing="4" />
            <Label Text="@borge.levisberg"
                   FontSize="12"
                   TextColor="{StaticResource AccentColor}"
                   HorizontalOptions="Center"
                   Opacity="0.7" />
        </VerticalStackLayout>

        <!-- Score & Turn Indicator -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="20" Margin="0,10">
            <Border Grid.Column="0" Background="#2C2C2C" Padding="15,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="PLAYER X" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                    <Label x:Name="ScoreXLabel" Text="0" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource PrimaryColor}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" Background="#2C2C2C" Padding="15,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="PLAYER O" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                    <Label x:Name="ScoreOLabel" Text="0" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource AccentColor}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Turn Indicator -->
        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="10" Margin="0,5">
            <Label Text="VEZ DE:" VerticalOptions="Center" TextColor="Gray" FontSize="14" FontAttributes="Bold" />
            <Border x:Name="TurnIndicatorFrame" Background="{StaticResource PrimaryColor}" Padding="20,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <Label x:Name="TurnLabel" Text="PLAYER X" TextColor="#121212" FontAttributes="Bold" FontSize="14" />
            </Border>
        </HorizontalStackLayout>
        <Border
            Grid.Row="3"
            Background="#1E1E1E"
            Padding="15">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Grid
                x:Name="GameGrid"
                RowDefinitions="*,*,*"
                ColumnDefinitions="*,*,*"
                RowSpacing="10"
                ColumnSpacing="10">
                <Button
                    x:Name="Button00"
                    Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button01"
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button02"
                    Grid.Row="0"
                    Grid.Column="2"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button10"
                    Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button11"
                    Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button12"
                    Grid.Row="1"
                    Grid.Column="2"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button20"
                    Grid.Row="2"
                    Grid.Column="0"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button21"
                    Grid.Row="2"
                    Grid.Column="1"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
                <Button
                    x:Name="Button22"
                    Grid.Row="2"
                    Grid.Column="2"
                    Style="{StaticResource GameButtonStyle}"
                    Clicked="OnButtonClicked" />
            </Grid>
        </Border>
        <Grid
            Grid.Row="4"
            ColumnDefinitions="*,*,*"
            ColumnSpacing="10"
            RowDefinitions="Auto,Auto"
            Margin="0,20,0,0"
            RowSpacing="15">
            <Button
                Grid.Column="0"
                Text="Reiniciar"
                Style="{StaticResource ControlButtonStyle}"
                Clicked="OnRestartButtonClicked">
                <Button.ImageSource>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph=""
                        Color="#FFFFFF"
                        Size="24" />
                </Button.ImageSource>
            </Button>
            <Button
                Grid.Column="1"
                x:Name="modeButton"
                Text="Modo"
                Style="{StaticResource ControlButtonStyle}"
                Clicked="OnToggleModeClicked">
                <Button.ImageSource>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph=""
                        Color="#FFFFFF"
                        Size="24" />
                </Button.ImageSource>
            </Button>
            <Button
                Grid.Column="2"
                x:Name="DifficultyButton"
                Text="Dificuldade"
                Style="{StaticResource ControlButtonStyle}"
                Clicked="OnDifficultyButtonClicked">
                <Button.ImageSource>
                    <FontImageSource
                        FontFamily="MaterialIcons"
                        Glyph=""
                        Color="#FFFFFF"
                        Size="24" />
                </Button.ImageSource>
            </Button>
            <Border
                Grid.Row="1"
                Grid.ColumnSpan="3"
                x:Name="DropdownFrame"
                IsVisible="False"
                Background="#3C3C3C"
                Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <StackLayout
                    Orientation="Horizontal"
                    HorizontalOptions="Center"
                    Spacing="10">
                    <Button
                        Text="Fácil"
                        Style="{StaticResource DropdownItemStyle}"
                        Clicked="OnDifficultySelected"
                        ClassId="0" />
                    <Button
                        Text="Médio"
                        Style="{StaticResource DropdownItemStyle}"
                        Clicked="OnDifficultySelected"
                        ClassId="1" />
                    <Button
                        Text="Difícil"
                        Style="{StaticResource DropdownItemStyle}"
                        Clicked="OnDifficultySelected"
                        ClassId="2" />
                </StackLayout>
            </Border>
        </Grid>
    </Grid>

        <!-- Custom Overlay -->
        <ContentView x:Name="GameOverOverlay" IsVisible="False" BackgroundColor="#CC121212">
            <Border Background="#1E1E1E"
                   Padding="40"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Stroke="#2C2C2C">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <Label x:Name="ResultIconLabel"
                           FontFamily="MaterialIcons"
                           Text=""
                           FontSize="80"
                           TextColor="{StaticResource PrimaryColor}"
                           HorizontalOptions="Center" />

                    <Label x:Name="ResultTitleLabel"
                           Text="VITÓRIA!"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <Label x:Name="ResultMessageLabel"
                           Text="Player X venceu!"
                           FontSize="18"
                           TextColor="Gray"
                           HorizontalOptions="Center" />

                    <Button Text="JOGAR NOVAMENTE"
                            Style="{StaticResource ControlButtonStyle}"
                            BackgroundColor="{StaticResource PrimaryColor}"
                            TextColor="#121212"
                            WidthRequest="200"
                            Margin="0,20,0,0"
                            Clicked="OnPlayAgainClicked" />
                </VerticalStackLayout>
            </Border>
        </ContentView>

        <!-- Tutorial Overlay -->
        <ContentView x:Name="TutorialOverlay" IsVisible="False" BackgroundColor="#E6121212">
            <Grid Padding="30">
                <Border Background="#1E1E1E"
                       Padding="30"
                       VerticalOptions="Center"
                       Stroke="{StaticResource PrimaryColor}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="25">
                        <Label Text="BEM-VINDO AO"
                               FontSize="14"
                               TextColor="Gray"
                               HorizontalOptions="Center" />
                        <Label Text="TIC TAC TOE"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="{StaticResource PrimaryColor}"
                               HorizontalOptions="Center" />

                        <BoxView HeightRequest="1" BackgroundColor="#2C2C2C" Margin="0,5" />

                        <HorizontalStackLayout Spacing="15">
                            <Label FontFamily="MaterialIcons" Text="" FontSize="24" TextColor="{StaticResource AccentColor}" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Modos de Jogo" FontAttributes="Bold" TextColor="White" />
                                <Label Text="Jogue contra um amigo ou contra a IA." FontSize="13" TextColor="Gray" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="15">
                            <Label FontFamily="MaterialIcons" Text="" FontSize="24" TextColor="{StaticResource AccentColor}" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Dificuldade IA" FontAttributes="Bold" TextColor="White" />
                                <Label Text="Escolha entre Fácil, Médio ou Difícil." FontSize="13" TextColor="Gray" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="15">
                            <Label FontFamily="MaterialIcons" Text="" FontSize="24" TextColor="{StaticResource AccentColor}" VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Feedback Visual" FontAttributes="Bold" TextColor="White" />
                                <Label Text="Observe as animações e cores nas jogadas." FontSize="13" TextColor="Gray" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <Button Text="COMEÇAR A JOGAR"
                                Style="{StaticResource ControlButtonStyle}"
                                BackgroundColor="{StaticResource PrimaryColor}"
                                TextColor="#121212"
                                HeightRequest="50"
                                Margin="0,15,0,0"
                                Clicked="OnCloseTutorialClicked" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ContentView>
    </Grid>
</ContentPage>